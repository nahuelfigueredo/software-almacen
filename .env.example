# Puerto del servidor (por defecto: 3000)
PORT=3000

# Clave de acceso al panel de administración de demo
# Cambiar por un valor seguro antes de desplegar en producción
DEMO_ADMIN_KEY=cambiar_por_clave_segura

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production_minimum_32_chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d
