# Puerto del servidor (por defecto: 3000)
PORT=3000

# Clave de acceso al panel de administración de demo
# Cambiar por un valor seguro antes de desplegar en producción
DEMO_ADMIN_KEY=cambiar_por_clave_segura

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production_minimum_32_chars
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ==================================
# MODO DEMO
# ==================================
DEMO_MODE=false
# Activar modo demo con datos de ejemplo
# true = Datos de demo, banner visible, auto-reset
# false = Modo producción limpio

DEMO_AUTO_RESET_HOURS=24
# Cada cuántas horas resetear datos de demo (0 = desactivado)

DEMO_BANNER_ENABLED=true
# Mostrar banner "MODO DEMO" en el header
